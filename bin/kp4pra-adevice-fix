#!/bin/bash
# KP4PRA TNC - fix ADEVICE in direwolf.conf from cm108 /dev/hidraw0 mapping.
# Runs at boot before direwolf.service so USB card renumbering self-heals.
# Match the CM108 on ANY /dev/hidraw* (the hidraw number is not stable
# across reboots / USB re-enumeration), and PREFER the name-based
# plughw:<name>,N over the number-based plughw:<num>,N, since the card
# NUMBER shifts with enumeration order while the name is stable.
target_adevice=$(cm108 2>/dev/null | awk '
/\/dev\/hidraw[0-9]+/ {
    for (i = 1; i <= NF; i++) {
        if ($i ~ /^plughw:[A-Za-z]/) { name_form = $i }
        else if ($i ~ /^plughw:[0-9]/) { if (num_form == "") num_form = $i }
    }
}
END { if (name_form != "") print name_form; else print num_form }')
[ -z "$target_adevice" ] && { echo "No CM108 hidraw0/ADEVICE mapping found."; exit 0; }
conf_file=$(realpath /home/kp4pra/direwolf.conf 2>/dev/null)
[ -f "$conf_file" ] || { echo "Config file not found: $conf_file"; exit 0; }
current_adevice=$(awk 'BEGIN{IGNORECASE=1} /^[[:space:]]*ADEVICE[[:space:]]+/ && $0 !~ /^#/ { print $2 }' "$conf_file")
echo "Current ADEVICE: ${current_adevice:-[not found]}  Target: $target_adevice"
if [ "$current_adevice" != "$target_adevice" ]; then
    if grep -qi '^\s*ADEVICE' "$conf_file"; then
        sed -i "s|^\s*ADEVICE\s\+.*|ADEVICE  $target_adevice|" "$conf_file"
    else
        sed -i "1i ADEVICE  $target_adevice" "$conf_file"
    fi
    echo "ADEVICE updated."
else
    echo "No change needed."
fi
