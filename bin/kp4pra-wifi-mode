#!/bin/bash
# KP4PRA TNC - switch wlan0 between client WiFi and the KP4PRA hotspot.
# Usage: kp4pra-wifi-mode ap|client|status|boot
# Parameters validated on Pi Zero 2 W (brcmfmac): explicit RSN/CCMP,
# PMF disabled (chip's AP mode fails 802.1X setup with PMF), pinned
# channel, rfkill/country pre-flight.
CONF="/rw/kp4pra-tnc/config.yaml"
val() { python3 -c "
import yaml,sys
try:
    c=yaml.safe_load(open('$CONF')) or {}
    print(c.get('wifi',{}).get('$1','$2'))
except Exception:
    print('$2')" 2>/dev/null; }
SSID="$(val ssid KP4PRA)"
PASS="$(val password qwerty1234)"
CHAN="$(val channel 6)"
APIP="172.16.0.1"

preflight() {
    rfkill unblock wifi 2>/dev/null || rfkill unblock all 2>/dev/null
    # NM keeps its own software radio switch (separate from rfkill); it is
    # often off on images flashed without WiFi credentials
    nmcli radio wifi on 2>/dev/null
    # AP mode requires a regulatory domain; set a default if unset
    iw reg get 2>/dev/null | grep -q "country 00" && iw reg set US 2>/dev/null
}

case "$1" in
  ap)
    preflight
    nmcli connection delete KP4PRA-AP >/dev/null 2>&1
    nmcli connection add type wifi ifname wlan0 con-name KP4PRA-AP autoconnect no \
        ssid "$SSID" 802-11-wireless.mode ap 802-11-wireless.band bg \
        802-11-wireless.channel "$CHAN" \
        wifi-sec.key-mgmt wpa-psk wifi-sec.psk "$PASS" \
        wifi-sec.proto rsn wifi-sec.pairwise ccmp wifi-sec.group ccmp \
        wifi-sec.pmf disable \
        ipv4.method shared ipv4.addresses ${APIP}/24 >/dev/null
    nmcli connection up KP4PRA-AP && \
      echo "AP mode: SSID $SSID, web UI at http://$APIP/ (client WiFi disconnected)"
    ;;
  client)
    nmcli connection down KP4PRA-AP 2>/dev/null
    nmcli device connect wlan0 2>/dev/null || true
    echo "Client mode: rejoining configured WiFi"
    ;;
  status)
    nmcli -t -f NAME connection show --active 2>/dev/null | grep -q "^KP4PRA-AP$" \
      && echo "ap" || echo "client"
    ;;
  boot)
    CLIENT_SSID="$(val client_ssid '')"
    # No client network configured -> come up as the KP4PRA hotspot.
    if [ -z "$CLIENT_SSID" ]; then
        echo "Boot: no client WiFi configured -> AP mode"
        exec "$0" ap
    fi
    # Client network configured: ensure a NM profile exists for it, then
    # wait up to 5 minutes for association; fall back to AP if it never joins.
    preflight
    CLIENT_PASS="$(val client_password '')"
    if ! nmcli -t -f NAME connection show | grep -qx "$CLIENT_SSID"; then
        if [ -n "$CLIENT_PASS" ]; then
            nmcli connection add type wifi ifname wlan0 con-name "$CLIENT_SSID" \
                ssid "$CLIENT_SSID" wifi-sec.key-mgmt wpa-psk wifi-sec.psk "$CLIENT_PASS" \
                autoconnect yes 2>/dev/null
        else
            nmcli connection add type wifi ifname wlan0 con-name "$CLIENT_SSID" \
                ssid "$CLIENT_SSID" autoconnect yes 2>/dev/null
        fi
    fi
    nmcli connection up "$CLIENT_SSID" 2>/dev/null || nmcli device connect wlan0 2>/dev/null || true
    echo "Boot: waiting up to 5 min for client WiFi '$CLIENT_SSID'..."
    for i in $(seq 1 60); do
        if nmcli -t -f DEVICE,STATE device | grep -q "^wlan0:connected$"; then
            echo "Boot: joined '$CLIENT_SSID' (client mode)"
            exit 0
        fi
        sleep 5
    done
    echo "Boot: client WiFi not joined after 5 min -> AP mode fallback"
    exec "$0" ap
    ;;
  *) echo "Usage: kp4pra-wifi-mode ap|client|status|boot"; exit 1 ;;
esac
